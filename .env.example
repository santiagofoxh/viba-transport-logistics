# Copy to .env for local development. On Render, set these in the Environment tab.

NODE_ENV=development
PORT=10000

# Rotate this. Render can auto-generate it for you (see render.yaml).
SESSION_SECRET=replace-with-a-long-random-string

# Used by /api/webhooks/trip-captured — the header X-Webhook-Secret must match.
WEBHOOK_SECRET=replace-with-a-long-random-string

# Password used to seed the demo accounts on first boot. Change this before first deploy.
DEFAULT_DEMO_PASSWORD=viba2026
